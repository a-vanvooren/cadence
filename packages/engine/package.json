{
  "name": "@cadence/engine",
  "version": "0.1.0",
  "description": "Framework-agnostic simulation engine that turns a typing profile + text + context into a timed, human-like keystroke plan.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "demo": "tsx examples/demo.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": ["typing", "keystroke-dynamics", "humanize", "behavioral", "cadence"],
  "devDependencies": {
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  }
}
